{
  "name": "agent-os-registry",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "version": "0.0.0",
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm --filter @rivet-dev/agent-os --filter @rivet-dev/agent-os-registry-types --filter './software/*' --filter './agent/*' --filter './file-system/*' --filter './tool/*' -r run build",
    "check-types": "pnpm --filter @rivet-dev/agent-os --filter @rivet-dev/agent-os-registry-types --filter './software/*' --filter './agent/*' --filter './file-system/*' --filter './tool/*' -r run check-types",
    "test": "vitest run"
  },
  "devDependencies": {
    "@rivet-dev/agent-os-common": "link:software/common",
    "@rivet-dev/agent-os": "link:../packages/core",
    "@rivet-dev/agent-os-curl": "link:software/curl",
    "@types/node": "^22.10.2",
    "@xterm/headless": "^6.0.0",
    "typescript": "^5.9.2",
    "vitest": "^2.1.9"
  }
}
