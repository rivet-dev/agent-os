+// Pyodide / emscripten HTTP client for httpfs.
+//
+// Replaces the upstream stub with an EM_ASYNC_JS-based implementation
+// that calls the host JS environment's native fetch() and uses JSPI
+// (JavaScript Promise Integration) to suspend the wasm side until the
+// response is available. This avoids:
+//
+//   - POSIX TCP sockets (Pyodide doesn't expose them — verified)
+//   - emscripten_fetch + XMLHttpRequest (XHR synchronous mode is
+//     deprecated and doesn't work cleanly in Node anyway)
+//   - mbedtls TLS vendoring (the host JS fetch handles HTTPS)
+//
+// Build flag required:
+//   -sJSPI=1   — wasm-side `await` on JS Promises via the
+//                 WebAssembly.Suspending API. Node 22+ supports it
+//                 natively (no flag needed in Node 24+).
 #include "httpfs_client.hpp"
 #include "http_state.hpp"
+#include "duckdb/common/exception.hpp"
+
+#include <emscripten.h>
+#include <cstdlib>
+#include <cstring>
+#include <sstream>
+#include <vector>
 
 namespace duckdb {
 
+// Calls JS `fetch(url, {method, headers, body})` and writes the
+// response status, body, body_len, and headers (as malloc'd C strings)
+// to the out parameters. Returns 0 on success, non-zero on failure.
+//
+// JSPI auto-wraps any `await` in this block so the wasm side suspends
+// until the JS Promise resolves. Node 22+ honors this without flags
+// (Node 24 confirmed working).
+// Signature uses int for pointer params — emscripten treats wasm32
+// pointers as int32, and using `*` in the EM_ASYNC_JS signature leaks
+// the * into the generated JS function declaration, producing
+// "Unexpected token '*'" at JS parse time.
+EM_ASYNC_JS(int, _httpfs_fetch_js, (int url_p, int method_p, int headers_flat_p,
+                                      int body_p, int body_len, int out_status, int out_body,
+                                      int out_body_len, int out_headers), {
+	try {
+		const url = UTF8ToString(url_p);
+		const method = UTF8ToString(method_p);
+		const headersFlat = UTF8ToString(headers_flat_p);
+		const headerObj = {};
+		for (const line of headersFlat.split("\n")) {
+			const colon = line.indexOf(":");
+			if (colon < 0) continue;
+			const key = line.slice(0, colon).trim();
+			const val = line.slice(colon + 1).trim();
+			if (key) headerObj[key] = val;
+		}
+		const init = { method, headers: headerObj };
+		if (body_p && body_len > 0) {
+			init.body = HEAPU8.slice(body_p, body_p + body_len);
+		}
+		const resp = await fetch(url, init);
+		HEAP32[out_status >> 2] = resp.status;
+
+		const respBuf = await resp.arrayBuffer();
+		const respBytes = new Uint8Array(respBuf);
+		const ptr = _malloc(respBytes.byteLength || 1);
+		if (respBytes.byteLength > 0) HEAPU8.set(respBytes, ptr);
+		HEAPU32[out_body >> 2] = ptr;
+		HEAPU32[out_body_len >> 2] = respBytes.byteLength;
+
+		const hdrLines = [];
+		resp.headers.forEach(function(v, k) { hdrLines.push(k + ": " + v); });
+		const hdrStr = hdrLines.join("\n") + "\n";
+		const hdrLen = lengthBytesUTF8(hdrStr) + 1;
+		const hdrPtr = _malloc(hdrLen);
+		stringToUTF8(hdrStr, hdrPtr, hdrLen);
+		HEAPU32[out_headers >> 2] = hdrPtr;
+		return 0;
+	} catch (err) {
+		// Surface the JS error message via the headers buffer so the
+		// C++ caller can include it in the HTTPResponse.reason field.
+		const msg = "X-Fetch-Error: " + (err && err.message ? err.message : String(err)) + "\n";
+		const msgLen = lengthBytesUTF8(msg) + 1;
+		const msgPtr = _malloc(msgLen);
+		stringToUTF8(msg, msgPtr, msgLen);
+		HEAPU32[out_headers >> 2] = msgPtr;
+		HEAP32[out_status >> 2] = 0;
+		HEAPU32[out_body >> 2] = 0;
+		HEAPU32[out_body_len >> 2] = 0;
+		return 1;
+	}
+});
+
+static void ParseResponseHeaders(const char *raw, HTTPHeaders &out, string &error_msg) {
+	if (!raw) return;
+	std::istringstream stream(raw);
+	std::string line;
+	while (std::getline(stream, line)) {
+		if (line.empty() || line == "\r") continue;
+		if (!line.empty() && line.back() == '\r') line.pop_back();
+		auto colon = line.find(':');
+		if (colon == std::string::npos) continue;
+		auto key = line.substr(0, colon);
+		auto val = line.substr(colon + 1);
+		while (!val.empty() && (val.front() == ' ' || val.front() == '\t')) val.erase(0, 1);
+		if (key == "X-Fetch-Error") {
+			error_msg = val;
+		} else {
+			out.Insert(key, val);
+		}
+	}
+}
+
+class EmscriptenFetchClient : public HTTPClient {
+public:
+	EmscriptenFetchClient(HTTPFSParams &http_params_p, const string &proto_host_port_p)
+	    : proto_host_port(proto_host_port_p), state(http_params_p.state),
+	      bearer_token(http_params_p.bearer_token) {
+	}
+
+	void Initialize(HTTPParams &http_p) override {
+		HTTPFSParams &http_params = (HTTPFSParams &)http_p;
+		state = http_params.state;
+		bearer_token = http_params.bearer_token;
+	}
+
+	unique_ptr<HTTPResponse> DoFetch(const char *method, const string &path, const HTTPHeaders &headers,
+	                                  const_data_ptr_t body_data, idx_t body_len) {
+		// Flatten headers into "key: value\n" lines for the JS side.
+		std::string flat;
+		for (auto it = headers.begin(); it != headers.end(); ++it) {
+			flat += it->first;
+			flat += ": ";
+			flat += it->second;
+			flat += "\n";
+		}
+		if (!bearer_token.empty()) {
+			flat += "Authorization: Bearer ";
+			flat += bearer_token;
+			flat += "\n";
+		}
+
+		string full_url = proto_host_port + path;
+
+		int status = 0;
+		void *body_ptr = nullptr;
+		size_t body_size = 0;
+		char *headers_ptr = nullptr;
+		_httpfs_fetch_js(reinterpret_cast<int>(full_url.c_str()), reinterpret_cast<int>(method),
+		                  reinterpret_cast<int>(flat.c_str()), reinterpret_cast<int>(body_data),
+		                  static_cast<int>(body_len), reinterpret_cast<int>(&status),
+		                  reinterpret_cast<int>(&body_ptr), reinterpret_cast<int>(&body_size),
+		                  reinterpret_cast<int>(&headers_ptr));
+
+		auto response = make_uniq<HTTPResponse>(static_cast<HTTPStatusCode>(status));
+
+		if (body_ptr && body_size > 0) {
+			response->body.assign(reinterpret_cast<const char *>(body_ptr), body_size);
+		}
+		if (body_ptr) std::free(body_ptr);
+
+		string error_msg;
+		ParseResponseHeaders(headers_ptr, response->headers, error_msg);
+		if (headers_ptr) std::free(headers_ptr);
+
+		if (status == 0 && !error_msg.empty()) {
+			response->reason = error_msg;
+		}
+
+		response->success = (status >= 200 && status < 300);
+		if (state) {
+			if (strcmp(method, "GET") == 0) state->get_count++;
+			else if (strcmp(method, "HEAD") == 0) state->head_count++;
+			else if (strcmp(method, "PUT") == 0) state->put_count++;
+			else if (strcmp(method, "POST") == 0) state->post_count++;
+			else if (strcmp(method, "DELETE") == 0) state->delete_count++;
+			state->total_bytes_received += body_size;
+		}
+		return response;
+	}
+
+	unique_ptr<HTTPResponse> Get(GetRequestInfo &info) override {
+		auto resp = DoFetch("GET", info.path, info.headers, nullptr, 0);
+		if (info.content_handler && !resp->body.empty()) {
+			info.content_handler(reinterpret_cast<const_data_ptr_t>(resp->body.data()), resp->body.size());
+		}
+		if (info.response_handler) {
+			info.response_handler(*resp);
+		}
+		return resp;
+	}
+
+	unique_ptr<HTTPResponse> Head(HeadRequestInfo &info) override {
+		return DoFetch("HEAD", info.path, info.headers, nullptr, 0);
+	}
+
+	unique_ptr<HTTPResponse> Put(PutRequestInfo &info) override {
+		return DoFetch("PUT", info.path, info.headers, info.buffer_in, info.buffer_in_len);
+	}
+
+	unique_ptr<HTTPResponse> Post(PostRequestInfo &info) override {
+		auto resp = DoFetch(info.send_post_as_get_request ? "GET" : "POST", info.path, info.headers, info.buffer_in,
+		                     info.buffer_in_len);
+		info.buffer_out = resp->body;
+		return resp;
+	}
+
+	unique_ptr<HTTPResponse> Delete(DeleteRequestInfo &info) override {
+		return DoFetch("DELETE", info.path, info.headers, nullptr, 0);
+	}
+
+	string proto_host_port;
+	shared_ptr<HTTPState> state;
+	string bearer_token;
+};
+
 unique_ptr<HTTPClient> HTTPFSUtil::InitializeClient(HTTPParams &http_params, const string &proto_host_port) {
-	throw InternalException("HTTPFSUtil::InitializeClient is not expected to be called");
+	return make_uniq<EmscriptenFetchClient>(reinterpret_cast<HTTPFSParams &>(http_params), proto_host_port);
 }
 
