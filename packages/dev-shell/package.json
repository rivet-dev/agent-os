{
  "name": "@rivet-dev/agent-os-dev-shell",
  "private": true,
  "type": "module",
  "bin": {
    "agent-os-dev-shell": "./dist/shell.js"
  },
  "scripts": {
    "build": "tsc",
    "check-types": "tsc --noEmit",
    "dev-shell": "tsx src/shell.ts",
    "test": "NODE_OPTIONS=--max-old-space-size=256 vitest run --fileParallelism=false"
  },
  "dependencies": {
    "@rivet-dev/agent-os": "workspace:*",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.19.3",
    "@xterm/headless": "^6.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
