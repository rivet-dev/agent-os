registry/software/python-wheels/wheels/_requirements.in
registry/software/python-wheels/wheels/_requirements.lock
registry/python-wheels/.toolchain/
registry/python-wheels/.build-cache/
registry/python-wheels/recipes/*/build/
registry/python-wheels/recipes/*/dist/
registry/python-wheels/recipes/*/src/*.egg-info/
registry/python-wheels/recipes/*/*.egg-info/

