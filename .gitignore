# Turborepo
**/.turbo

# Node.js and pnpm
node_modules/
npm-debug.log*
pnpm-debug.log*
.pnpm-store/

# TypeScript
*.tsbuildinfo
dist/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Secrets
secrets/**/*

.opencode

# Registry build artifacts
registry/native/target/
registry/native/vendor/
registry/native/c/build/
registry/native/c/vendor/
registry/native/c/libs/
