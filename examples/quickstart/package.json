		"@rivet-dev/agent-os-claude": "workspace:*",
		"@rivet-dev/agent-os-codex-agent": "workspace:*",
		"@rivet-dev/agent-os-opencode": "workspace:*",
		"@rivet-dev/agent-os-pi": "workspace:*",
		"@rivet-dev/agent-os-python-wheels": "workspace:*",
		"@rivet-dev/agent-os-s3": "workspace:*",
		"pyodide": "^0.29.3",
		"zod": "^4.1.11"
	},
	"devDependencies": {
		"@types/node": "^22.10.2",
		"tsx": "^4.19.0",
		"typescript": "^5.7.2"
	}
}
